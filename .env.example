# Credenciais da API Getrak
# Chave (já em base64 conforme fornecido pela Getrak): "Authorization: Basic <GETRAK_API_KEY>"
GETRAK_API_KEY=__PREENCHER__

# Login de integração na Getrak
GETRAK_USERNAME=__PREENCHER__
GETRAK_PASSWORD=__PREENCHER__

# Credenciais da API DO Telematics (api-gateway.dotelematics.com)
# Tenant API key (header "apikey"); login do usuário (email/senha)
DOTELEMATICS_APIKEY=__PREENCHER__
DOTELEMATICS_USERNAME=__PREENCHER__
DOTELEMATICS_PASSWORD=__PREENCHER__

# Porta do backend
PORT=3001

# Contato para o User-Agent enviado ao Nominatim (reverse geocoding).
# A política de uso do Nominatim exige um e-mail/URL de contato válido,
# senão o serviço pode bloquear ou rate-limitar as requisições.
NOMINATIM_CONTACT=__PREENCHER__

# Google Cloud Vision API key (para leitura de IMEI por foto).
# Criar em https://console.cloud.google.com → APIs & Services → Credentials.
# Restringir a key a "Cloud Vision API" apenas.
GOOGLE_VISION_API_KEY=__PREENCHER__
