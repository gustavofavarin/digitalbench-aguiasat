{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/search.js": {
      "maxDuration": 60
    },
    "api/health.js": {
      "maxDuration": 10
    },
    "api/ocr.js": {
      "maxDuration": 30
    },
    "api/cron/refresh.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh",
      "schedule": "0 * * * *"
    }
  ]
}
